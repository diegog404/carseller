@model carseller.Models.ViewModels.SaleFormViewModel

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

<h2>Edit Sale</h2>
<hr />
<div class="row">
    <div class="col-md-6">

        <form asp-action="Edit">
            <input type="hidden" asp-for="Sale.Id" />
            <div class="form-group">

                <label asp-for="Sale.Value" class="control-label"></label>
                <input asp-for="Sale.Value" class="form-control" />
                <span asp-validation-for="Sale.Value" class="text-danger"></span>
            </div>
            <div class="form-group">

                <label asp-for="Sale.Comission" class="control-label"></label>
                <input asp-for="Sale.Comission" class="form-control" />
                <span asp-validation-for="Sale.Comission" class="text-danger"></span>
            </div>
            <div class="form-group">

                <label asp-for="Sale.Date" class="control-label"></label>
                <input asp-for="Sale.Date" class="form-control" />
                <span asp-validation-for="Sale.Date" class="text-danger"></span>
            </div>
            <div class="form-group">

                <label asp-for="Sale.Status" class="control-label"></label>
                <input asp-for="Sale.Status" class="form-control" />
                <span asp-validation-for="Sale.Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Sale.Client" class="control-label"></label>
                <select asp-for="Sale.ClientId" asp-items="@(new SelectList(Model.Clients, "Id", "Name"))" class="form-control"></select>
            </div>

            <div class="form-group">
                <label asp-for="Sale.User" class="control-label"></label>
                <select asp-for="Sale.UserId" asp-items="@(new SelectList(Model.Users, "Id", "Name"))" class="form-control"></select>
            </div>

            <div class="form-group">
                <input type="submit" value="Edit" class="btn btn-dark" />
                <a asp-action="Index">Back to list</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}

