@model carseller.Models.ViewModels.HomeViewModel;

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h3 class="display-4">Welcome, @User.Identity.Name!</h3>
</div>

<h3 class="mt-4">Pending Sales</h3>
<table class="table table-striped table-hover">
    <thead>
        <tr class="table-primary">
            <th>
                Value
            </th>
            <th>
                Date
            </th>
            <th>
                Comission
            </th>
            <th>
                Client
            </th>
        </thead>

        <tbody>

            @foreach (var sale in Model.SalesInProgress)
            {
                <tr>
                    <td>@sale.Value.ToString("F3")</td>

                    <td>@sale.Date.ToString("dd/MM/yyyy HH:mm")</td>

                    <td>@sale.Comission.ToString("F3")</td>

                    <td>@sale.ClientId</td>
                </tr>
            }

            
        </tbody>
    </table>

    <h3 class="mt-4">Billed Sales this month</h3>
    <table class="table table-striped table-hover">
        <thead>
            <tr class="table-primary">
                <th>
                    Value
                </th>
                <th>
                    Date
                </th>
                <th>
                    Comission
                </th>
                <th>
                    Client
                </th>
            </thead>

            <tbody>

                @foreach (var sale in Model.BilledSales)
                {
                    <tr>
                        <td>@sale.Value.ToString("F3")</td>

                        <td>@sale.Date.ToString("dd/MM/yyyy HH:mm")</td>

                        <td>@sale.Comission.ToString("F3")</td>

                        <td>@sale.ClientId</td>
                    </tr>
                }

            
            </tbody>
        </table>

        <h3 class="mt-4">Vehicles being negociated</h3>
        <table class="table table-striped table-hover">
            <thead>
                <tr class="table-primary">
                    <th>
                        Type
                    </th>
                    <th>
                        License Plate
                    </th>
                    <th>
                        Model
                    </th>
                    <th>
                        Year
                    </th>
                    <th>
                        Price
                    </th>
                    <th>
                        Company
                    </th>
                </thead>

                <tbody>

                    @foreach (var vehicle in Model.NegociatedVehicles)
                    {
                        <tr>
                            <td>@vehicle.Type</td>

                            <td>@vehicle.LicensePlate</td>

                            <td>@vehicle.Model</td>

                            <td>@vehicle.Year</td>

                            <td>@vehicle.Price.ToString("F3")</td>

                            <td>@vehicle.CompanyId</td>
                        </tr>
                    }
                </tbody>
            </table>

            <h3 class="text-primary">Monthly Comission: R$ @Model.MonthlyComission.ToString("F3")</h3>
            <h3 class="text-primary">Expected Comission: R$ @Model.ExpectedComission.ToString("F3")</h3>


        

      


        


