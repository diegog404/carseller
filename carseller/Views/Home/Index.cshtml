@model carseller.Models.ViewModels.HomeViewModel;

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h3 class="display-4">Welcome, @User.Identity.Name!</h3>
</div>

<h3 class="mt-4">Pending Sales</h3>
<table class="table table-striped table-hover">
    <thead>
        <tr class="table-primary">
            <th>
                Value
            </th>
            <th>
                Date
            </th>
            <th>
                Comission
            </th>
            <th>
                Client
            </th>
        </thead>

        <tbody>

            @foreach (var sale in Model.SalesInProgress)
            {
                <tr>
                    <td>@sale.Value.ToString("F3")</td>

                    <td>@sale.Date.ToString("dd/MM/yyyy HH:mm")</td>

                    <td>@sale.Comission.ToString("F3")</td>

                    <td>@sale.ClientId</td>
                </tr>
            }

            
        </tbody>
    </table>

    <h3 class="mt-4">Billed Sales this month</h3>
    <table class="table table-striped table-hover">
        <thead>
            <tr class="table-primary">
                <th>
                    Value
                </th>
                <th>
                    Date
                </th>
                <th>
                    Comission
                </th>
                <th>
                    Client
                </th>
            </thead>

            <tbody>

                @foreach (var sale in Model.BilledSales)
                {
                    <tr>
                        <td>@sale.Value.ToString("F3")</td>

                        <td>@sale.Date.ToString("dd/MM/yyyy HH:mm")</td>

                        <td>@sale.Comission.ToString("F3")</td>

                        <td>@sale.ClientId</td>
                    </tr>
                }

            
            </tbody>
        </table>

        <div class="row mt-4">

            <div class="col-lg-3 col-md-6 col-sm-12">
                <div class="card bg-primary text-white shadow p-3">

                    <h3>Monthly Comission</h3>
                    <h2>@Model.MonthlyComission.ToString("F3")</h2>
                </div>
            </div>
        
            <div class="col-lg-3 col-md-6 col-sm-12">
                <div class="card bg-primary text-white shadow p-3">

                    <h3>Expected Comission</h3>
                    <h2>@Model.ExpectedComission.ToString("F3")</h2>
                </div>
            </div>
        </div>

        

      


        


