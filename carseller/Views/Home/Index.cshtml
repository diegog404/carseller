@model carseller.Models.ViewModels.HomeViewModel;

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h3 class="display-4">Welcome, @User.Identity.Name!</h3>
</div>

<h3 class="mt-4">Pending Sales</h3>
<table class="table table-striped table-hover">
    <thead>
        <tr class="table-success">
            <th>
                Value
            </th>
            <th>
                Date
            </th>
            <th>
                Comission
            </th>
            <th>
                Client
            </th>
        </thead>

        <tbody>

            @foreach (var sale in Model.SalesInProgress)
            {
                <tr>
                    <td>@sale.Value.ToString("F4")</td>

                    <td>@sale.Date.ToString("dd/MM/yyyy HH:mm")</td>

                    <td>@sale.Comission.ToString("F4")</td>

                    <td>@sale.ClientId</td>
                </tr>
            }
            

        </tbody>
    </table>


